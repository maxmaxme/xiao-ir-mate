# HA temperature sensor for the room this unit controls — shown as the AC's
# current_temperature. Change this and re-flash when moving the firmware to a
# device in a different room.
room_temp_entity: "sensor.your_room_temperature"
room_humidity_entity: "sensor.your_room_humidity"
